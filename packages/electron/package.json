{
  "name": "react-insight",
  "version": "0.1.0",
  "description": "Desktop app that shows why your React components render",
  "main": "dist/main/index.js",
  "scripts": {
    "dev:main": "tsup --config tsup.config.ts",
    "dev:renderer": "vite --port 5188 --strictPort",
    "dev": "tsup --config tsup.config.ts && concurrently -k -n main,renderer,electron \"tsup --config tsup.config.ts --watch\" \"vite --port 5188 --strictPort\" \"wait-on tcp:5188 && electron .\"",
    "build:main": "tsup --config tsup.config.ts",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "package": "npm run build && electron-builder"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.0"
  }
}
